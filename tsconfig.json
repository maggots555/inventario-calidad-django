{
  "compilerOptions": {
    /* Opciones Base */
    "target": "ES2019", // Compila a JavaScript ES2019 (compatible con navegadores modernos, incluye flatMap)
    "lib": ["ES2019", "DOM"], // Incluye librerías ES2019 y DOM
    "strict": true, // ¡La magia de TypeScript! Activa todos los chequeos estrictos.
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Opciones Clave para Django */
    "outDir": "static/js", // ¡IMPORTANTE! Aquí es donde guardará los .js compilados.
    "rootDir": "static/ts", // Directorio raíz de los archivos .ts fuente.
    "sourceMap": true, // Crea archivos .map para depurar tu .ts original en el navegador
  },
  /* Dónde buscará TypeScript */
  "include": [
    "static/ts/**/*.ts",
    "static/ts/**/*.d.ts"
  ],
  /* Workers tienen tsconfig propio (WebWorker); no compilarlos con lib DOM */
  "exclude": [
    "static/ts/jpeg_encode_worker.ts"
  ]
}