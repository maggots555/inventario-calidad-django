# 🔐 PLANTILLA DE VARIABLES DE ENTORNO
# Este archivo SÍ se sube a GitHub como ejemplo
# Copia este archivo como .env y llena con tus credenciales reales

# Django Secret Key (genera uno nuevo en https://djecrety.ir/)
SECRET_KEY=tu-secret-key-aqui

# Django Debug Mode (True para desarrollo, False para producción)
DEBUG=True

# Configuración de Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_aqui
DEFAULT_FROM_EMAIL=Score Card System <tu_correo@empresa.com>

# Email específico para Servicio Técnico (notificaciones de piezas, órdenes, etc.)
# Si no se configura, usará DEFAULT_FROM_EMAIL
SERVICIO_TECNICO_FROM_EMAIL=Servicio Tecnico System <tu_correo@empresa.com>

# Email del Jefe de Calidad (recibe copia de todas las notificaciones)
JEFE_CALIDAD_EMAIL=jefe_calidad@empresa.com
JEFE_CALIDAD_NOMBRE=Jefe de Calidad

# Segundo Jefe de Calidad (también recibe copia de todas las notificaciones)
JEFE_CALIDAD_2_EMAIL=segundo_jefe@empresa.com
JEFE_CALIDAD_2_NOMBRE=Segundo Jefe de Calidad

# Jefe General (también recibe copia de todas las notificaciones)
JEFE_GENERAL_EMAIL=jefe_general@empresa.com
JEFE_GENERAL_NOMBRE=Jefe General

# Ayudante de Compras (también recibe copia de todas las notificaciones)
AYUDANTE_COMPRAS_EMAIL=compras@empresa.com
AYUDANTE_COMPRAS_NOMBRE=Ayudante Compras

# ============================================================================
# CORREOS RHITSO - SERVICIO TÉCNICO
# ============================================================================
# Destinatarios principales de RHITSO para envío de equipos
# Contacto 1 - D. García
RHITSO_CONTACTO_1_NOMBRE=Team Rhitso - D. García
RHITSO_CONTACTO_1_EMAIL=contacto1@rhitso.com.mx

# Contacto 2 - J. Roque
RHITSO_CONTACTO_2_NOMBRE=Team Rhitso - J. Roque
RHITSO_CONTACTO_2_EMAIL=contacto2@rhitso.com.mx

# Contacto 3 - Laboratorio
RHITSO_CONTACTO_3_NOMBRE=Team Rhitso - Laboratorio
RHITSO_CONTACTO_3_EMAIL=laboratorio@rhitso.com.mx

# Contacto 4 - Correo de prueba (opcional, dejar vacío si no se usa)
RHITSO_CONTACTO_4_NOMBRE=
RHITSO_CONTACTO_4_EMAIL=

# ============================================================================
# CONFIGURACIÓN DE ALMACENAMIENTO CON DISCO ALTERNO
# ============================================================================
# Ruta del disco alterno para cuando el disco principal se llene
# Ejemplo: D:/Media_Django/inventario-calidad-django/media
# Deja vacío para usar solo el disco principal
ALTERNATE_STORAGE_PATH=D:/Media_Django/inventario-calidad-django/media

# Espacio mínimo libre (en GB) antes de cambiar al disco alterno
# Si el disco principal tiene menos de este espacio, se usa el alterno
MIN_FREE_SPACE_GB=5

# ============================================================================
# CONFIGURACIÓN DE UPLOADS
# ============================================================================
# Directorio temporal para uploads de archivos grandes
# True = usar directorio dedicado /var/www/django_temp (producción Linux)
# False = usar directorio temporal del sistema (desarrollo Windows/Mac)
# 
# IMPORTANTE: En producción con Gunicorn+systemd, se DEBE usar True para evitar
# problemas de FileNotFoundError con namespaces /tmp privados corruptos.
# En desarrollo local (Windows/Mac), usar False es más simple.
USE_CUSTOM_TEMP_DIR=False

# ============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================================================
# Para desarrollo en Windows, usar SQLite (más simple):
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Para producción en Ubuntu con PostgreSQL, descomentar y configurar:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=nombre_base_datos
# DB_USER=usuario_postgres
# DB_PASSWORD=password_postgres
# DB_HOST=localhost
# DB_PORT=5432

# ============================================================================
# HOSTS Y CSRF PERMITIDOS
# ============================================================================
# Lista de hosts permitidos (separados por coma, sin espacios)
# Incluir localhost para desarrollo y las IPs/dominios de producción
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.10.133

# Lista de orígenes confiables para CSRF (separados por coma, sin espacios)
# Usar http:// para desarrollo local y https:// para producción
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://192.168.10.133

# URL pública del sitio — usada en links de correos (feedback, encuestas, etc.)
# En desarrollo: http://localhost:8000
# En producción: https://tudominio.com
SITE_URL=http://localhost:8000

# Para producción, agregar tu dominio:
# ALLOWED_HOSTS=localhost,127.0.0.1,tudominio.com,www.tudominio.com
# CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com
# SITE_URL=https://tudominio.com

# ============================================================================
# INTEGRACIÓN CON IA — MEJORA DE DIAGNÓSTICOS SIC
# Soporta dos proveedores: Ollama (local/Tailscale) y Google Gemini (nube)
# El botón "Mejorar Diag. con IA" aparece si al menos uno está habilitado.
# ============================================================================

# --- PROVEEDOR 1: OLLAMA (modelos locales o remotos via Tailscale) ----------

# Habilita los modelos de Ollama en el selector de IA.
# False = los modelos de Ollama no aparecen en la UI.
OLLAMA_ENABLED=False

# URL base del servidor Ollama.
# Opciones:
#   Desarrollo con GPU local:  http://localhost:11434
#   Producción via Tailscale:  http://100.64.x.y:11434
# IMPORTANTE: No agregar comentarios en la misma línea del valor.
OLLAMA_BASE_URL=http://localhost:11434

# Modelo predeterminado (se usa si OLLAMA_MODELS no está definido).
# Opciones recomendadas: gemma3:12b (mayor calidad) o gemma3:4b (más rápido)
# IMPORTANTE: No agregar comentarios en la misma línea del valor.
OLLAMA_MODEL=gemma3:12b

# Lista de modelos Ollama disponibles para seleccionar en el modal.
# Separados por coma, sin espacios alrededor de las comas.
# Si se omite, se usa solo el valor de OLLAMA_MODEL.
# IMPORTANTE: No agregar comentarios en la misma línea del valor.
OLLAMA_MODELS=gemma3:12b,gemma3:4b,qwen2.5-coder:7b

# Timeout en segundos antes de abortar la llamada a Ollama.
# 120s es apropiado para modelos 12B con GPU dedicada.
OLLAMA_TIMEOUT=120

# Timeout específico para análisis de imágenes con IA (visión).
# Más alto que OLLAMA_TIMEOUT: el modelo procesa múltiples imágenes y puede
# estar en cola detrás de otras tareas. Las tareas de visión siempre corren
# en background via Celery — no hay riesgo de timeout de HTTP/Cloudflare.
# Recomendado: 600s (10 min) = hasta ~4 min en cola + ~2 min de inferencia.
OLLAMA_VISION_TIMEOUT=600

# Máximo de imágenes enviadas al modelo de visión por análisis de ingreso.
# gemma4 tiene 128K tokens — 8 imágenes ≈ 16K tokens (12% del límite).
# Aumentar es seguro en contexto pero incrementa el payload por red y el tiempo.
OLLAMA_MAX_IMAGENES_IA=8

# --- PROVEEDOR 2: GOOGLE GEMINI (API en la nube — Google AI Studio) ---------

# Habilita los modelos de Gemini en el selector de IA.
# True = los modelos de Gemini aparecen en la UI y están disponibles.
GEMINI_ENABLED=False

# API Key generada en Google AI Studio: https://aistudio.google.com/app/apikey
# IMPORTANTE: Mantén este valor SECRETO. Nunca lo expongas en código o commits.
GEMINI_API_KEY=

# Modelo de Gemini predeterminado (se usa si GEMINI_MODELS no está definido).
# Opciones disponibles con generateContent:
#   gemini-2.5-flash   → más reciente, rápido y de alta calidad (recomendado)
#   gemini-2.5-pro     → máxima calidad, más lento
#   gemini-2.0-flash   → estable, bajo costo
#   gemini-2.0-flash-lite → ultra rápido, menor calidad
# IMPORTANTE: No agregar comentarios en la misma línea del valor.
GEMINI_MODEL=gemini-2.5-flash

# Lista de modelos Gemini disponibles para seleccionar en el modal.
# Separados por coma, sin espacios alrededor de las comas.
# Si se omite, se usa solo el valor de GEMINI_MODEL.
# IMPORTANTE: No agregar comentarios en la misma línea del valor.
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite

# Timeout en segundos antes de abortar la llamada a la API de Gemini.
# 60s es suficiente para la API de Google (responde mucho más rápido que Ollama local).
GEMINI_TIMEOUT=60

# ============================================================================
# MODELO PARA EL CHATBOT DE SEGUIMIENTO DEL CLIENTE
# ============================================================================
# Modelo predeterminado para el chat de IA en la vista pública de seguimiento.
# Se recomienda un modelo pequeño y rápido (conversación, no corrección de texto).
# El dispatcher detecta automáticamente el proveedor:
#   - Nombre que empieza con "gemini" → API de Google Gemini
#   - Cualquier otro → Ollama (local/Tailscale)
#
# Default: gemma4:e2b (modelo de Google para Ollama, ~2B parámetros, muy rápido)
# Alternativas:
#   gemma4:e2b              → Ollama, local, 2B params, ideal para chat corto
#   llama3.2:3b             → Ollama, local, 3B params
#   gemini-2.0-flash        → Gemini API, nube, muy rápido (consume tokens)
#   gemini-2.0-flash-lite   → Gemini API, nube, mínimo costo
#
CHAT_SEGUIMIENTO_MODEL=gemma4:e2b

# ============================================================================
# CONFIGURACIÓN DE BACKUP A GOOGLE DRIVE (rclone)
# ============================================================================
# Estas variables son INFORMATIVAS — rclone usa su propio archivo de config
# (~/.config/rclone/rclone.conf) que se genera con "rclone config"
#
# Para configurar el backup a Drive, consulta la guía completa en:
#   docs/guias/setup/CONFIGURAR_RCLONE_GDRIVE.md
#
# Resumen del proceso:
#   1. Ejecutar: /var/www/inventario-django/bin/rclone config
#   2. Crear un remote llamado "gdrive" apuntando a Google Drive
#   3. Ejecutar: bash /var/www/inventario-django/scripts/setup_backup_drive_cron.sh
#
# Los scripts de backup están en:
#   /var/www/inventario-django/scripts/backup_gdrive.sh        (backup principal)
#   /var/www/inventario-django/scripts/setup_backup_drive_cron.sh  (instala cron)
#
# El cron corre todos los días a las 3:00 AM (1 hora después del backup de BD)
# Log de resultados: /var/log/backup_gdrive.log

